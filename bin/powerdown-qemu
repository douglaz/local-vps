#!/run/current-system/sw/bin/bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(/run/current-system/sw/bin/id -un)}/bin:/nix/var/nix/profiles/default/bin:${PATH:-}"

VM_DIR="${LOCAL_VPS_DIR:-$HOME/local-vps}"
MONITOR="$VM_DIR/run/qemu-monitor.sock"
PIDFILE="$VM_DIR/run/qemu.pid"

if [ -S "$MONITOR" ]; then
  timeout 2 bash -c 'printf "system_powerdown\n" | nc -U "$1"' _ "$MONITOR" || true
fi

if [ -f "$PIDFILE" ]; then
  PID="$(cat "$PIDFILE")"
  for _ in $(seq 1 90); do
    if ! kill -0 "$PID" >/dev/null 2>&1; then
      exit 0
    fi
    sleep 1
  done
fi
